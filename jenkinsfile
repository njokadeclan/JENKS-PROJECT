pipeline{
    
    agent any

    stages{

        stage('continuous download') {

            steps{
                git branch: 'main', url: 'https://github.com/njokadeclan/JENKS-PROJECT.git'
            }
        }
        stage('unit test') {

            steps{
                sh'mvn test'
            }
        }
        stage('integration test') {

            steps{
                sh'mvn verify -DskipUnitTests'
            }
        }
        stage('continuous build') {

            steps{
                sh'mvn clean install'
            }
        }
        stage('static test analysis') {

            steps{

                script{
                    withSonarQubeEnv(credentialsId: 'sonar-token') {
                        sh 'mvn clean package sonar:sonar'
                    }
                }
            }
        }
        stage('quality gate analysis') {

            steps{

                script{
                    waitForQualityGate abortPipeline: false, credentialsId: 'sonar-token'
                }
            }
        }
        stage('uplaod artifact to nexus') {

            steps{

                script{
                    nexusArtifactUploader artifacts: [[artifactId: 'springboot', classifier: '', file: 'target/Uber.jar', type: 'jar']], credentialsId: 'nexus-auth', groupId: 'com.example', nexusUrl: '52.14.127.86:8081', nexusVersion: 'nexus3', protocol: 'http', repository: 'jenks-project', version: '1.0.0'
                }
            }
        }
    }

}